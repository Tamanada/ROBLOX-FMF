{
  "name": "full-moon-festival",
  "tree": {
    "$className": "DataModel",
    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Packages": {
        "$path": {
          "optional": "Packages"
        }
      }
    },
    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      },
      "Tests": {
        "$path": "tests"
      }
    },
    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    },
    "Workspace": {
      "$properties": {
        "StreamingEnabled": true
      }
    }
  }
}
